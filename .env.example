# Copia questo file in ".env" e riempi i valori. NON committare il .env vero!

# Token del bot (da @BotFather) - RIGENERALO, quello vecchio l'hai esposto
TELEGRAM_TOKEN=incolla_qui_il_token_nuovo

# Web API key del progetto Firebase (questa NON e' segreta, e' gia' nel sito)
FIREBASE_API_KEY=AIzaSyCfhxHKn73vdmhX7PwGrb8U8A4_BxMWtzs

# Password per diventare admin del bot (comando /admin <password>)
