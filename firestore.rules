rules_version = '2';

// ==========================================================================
// Regole di sicurezza Firestore per il progetto "nellokpi"
//
// COME APPLICARLE:
//  1. Firebase Console -> Firestore Database -> scheda "Regole"
//  2. Incolla TUTTO questo contenuto
//  3. Premi "Pubblica"
//
// Cosa fanno:
//  - users/{uid}      : ogni utente legge/scrive SOLO il proprio documento
//  - telegram_links   : gestiti dal bot (service account), che bypassa
//                       queste regole; i client web NON vi accedono
//  - tutto il resto   : negato
// ==========================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // Dati KPI: solo il proprietario, e solo se autenticato
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Collegamenti Telegram: scritti dal bot col service account (admin),
    // che ignora le regole. Ai client normali viene negato l'accesso.
    match /telegram_links/{tgId} {
      allow read, write: if false;
    }

    // Admin del bot: gestiti solo dal service account, client esclusi.
    match /bot_admins/{tgId} {
      allow read, write: if false;
    }

    // Qualsiasi altro percorso: negato di default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
